{
  "name": "yogmandu-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "deploy:cpanel": "next build --webpack && node scripts/package-cpanel.mjs",
    "deploy": "next build --webpack && node scripts/assemble-standalone.mjs && node scripts/deploy-webdav.mjs",
    "deploy:sync": "node scripts/assemble-standalone.mjs && node scripts/deploy-webdav.mjs",
    "build:cf": "opennextjs-cloudflare build && wrangler deploy --config wrangler-bundle.jsonc --dry-run --outdir .open-next/cf-bundle && cp .open-next/cf-bundle/worker.js .open-next/assets/_worker.js && node scripts/gen-routes.mjs",
    "build:cf:debug": "npm run build:cf && node scripts/debug-patch.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.106.0",
    "@types/three": "^0.184.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.94.0"
  }
}
